APP_NAME="ALWAAB ERP+CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Dubai
APP_URL=http://localhost:8080
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_AE

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=alwaab
DB_USERNAME=alwaab
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120

BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=info@alwaab.ae
MAIL_FROM_NAME="Al Waab Building Materials"

# Shared secret with alwaab-website (generate: php -r "echo bin2hex(random_bytes(32));")
WEBSITE_API_KEY=

# Comma-separated website origins allowed to call the ERP API
CORS_ALLOWED_ORIGINS=https://alwaab.ae,https://www.alwaab.ae

OPENAI_API_KEY=
AI_STUDIO_TEXT_MODEL=gpt-4o-mini
AI_STUDIO_IMAGE_MODEL=dall-e-3
AI_STUDIO_IMAGE_SIZE=1024x1024
AI_STUDIO_DEFAULT_CREDITS=10
LUMA_API_KEY=
LUMA_API_URL=https://api.lumalabs.ai/dream-machine/v1/generations
RUNWAY_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

REVERB_APP_ID=alwaab-local
REVERB_APP_KEY=alwaab-reverb-key
REVERB_APP_SECRET=alwaab-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8081
REVERB_SCHEME=http
REVERB_BROADCAST_HOST=reverb
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8081

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
