# انسخ هذا الملف إلى: alwaab-erp/.env على السيرفر
# cPanel → File Manager → alwaab/alwaab-erp/.env

APP_NAME="ALWAAB ERP+CRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Dubai
APP_URL=https://erp.alwaab.ae
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# PostgreSQL (موصى به — cPanel → PostgreSQL Databases)
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=YOUR_CPANEL_DB_NAME
DB_USERNAME=YOUR_CPANEL_DB_USER
DB_PASSWORD=YOUR_CPANEL_DB_PASSWORD

# بدون Redis على cPanel — استخدم قاعدة البيانات
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_HOST=mail.alwaab.ae
MAIL_PORT=465
MAIL_USERNAME=info@alwaab.ae
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=info@alwaab.ae
MAIL_FROM_NAME="Al Waab Building Materials"

# مفتاح الربط مع الموقع (نفس القيمة في erp-config.js)
WEBSITE_API_KEY=GENERATE_STRONG_KEY_HERE
CORS_ALLOWED_ORIGINS=https://alwaab.ae,https://www.alwaab.ae

OPENAI_API_KEY=
LUMA_API_KEY=
AI_STUDIO_DEFAULT_CREDITS=10

SANCTUM_STATEFUL_DOMAINS=erp.alwaab.ae,www.erp.alwaab.ae

VITE_APP_NAME="${APP_NAME}"
